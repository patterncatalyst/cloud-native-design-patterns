{
  "info": {
    "name": "Orders API",
    "_postman_id": "cndp-orders-v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" },
    { "key": "order_id", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/healthz"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('status is ok', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('ok');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Orders CRUD",
      "item": [
        {
          "name": "Create order",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/orders",
            "body": {
              "mode": "raw",
              "raw": "{\"sku\": \"widget-a\", \"quantity\": 3}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('201 Created', () => pm.response.to.have.status(201));",
                  "pm.test('under 500ms', () => pm.expect(pm.response.responseTime).to.be.below(500));",
                  "const body = pm.response.json();",
                  "pm.test('returns an id', () => pm.expect(body).to.have.property('id'));",
                  "pm.test('sku matches', () => pm.expect(body.sku).to.eql('widget-a'));",
                  "pm.test('quantity matches', () => pm.expect(body.quantity).to.eql(3));",
                  "pm.test('status is placed', () => pm.expect(body.status).to.eql('placed'));",
                  "pm.collectionVariables.set('order_id', body.id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get order by ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/orders/{{order_id}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('id matches', () => pm.expect(body.id).to.eql(parseInt(pm.collectionVariables.get('order_id'))));",
                  "pm.test('has sku', () => pm.expect(body).to.have.property('sku'));",
                  "pm.test('has status', () => pm.expect(body.status).to.eql('placed'));"
                ]
              }
            }
          ]
        },
        {
          "name": "List orders",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/orders"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('returns an array', () => pm.expect(body).to.be.an('array'));",
                  "pm.test('at least one order', () => pm.expect(body.length).to.be.at.least(1));"
                ]
              }
            }
          ]
        },
        {
          "name": "Cancel order",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/orders/{{order_id}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('204 No Content', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get cancelled order",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/orders/{{order_id}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('status is cancelled', () => pm.expect(body.status).to.eql('cancelled'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Validation",
      "item": [
        {
          "name": "Reject zero quantity",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/orders",
            "body": {
              "mode": "raw",
              "raw": "{\"sku\": \"widget-a\", \"quantity\": 0}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('422 Unprocessable', () => pm.response.to.have.status(422));"
                ]
              }
            }
          ]
        },
        {
          "name": "Reject missing sku",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/orders",
            "body": {
              "mode": "raw",
              "raw": "{\"quantity\": 5}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('422 Unprocessable', () => pm.response.to.have.status(422));"
                ]
              }
            }
          ]
        },
        {
          "name": "Reject negative quantity",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/orders",
            "body": {
              "mode": "raw",
              "raw": "{\"sku\": \"widget-a\", \"quantity\": -1}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('422 Unprocessable', () => pm.response.to.have.status(422));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get nonexistent order",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/orders/99999"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('404 Not Found', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
